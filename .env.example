# Environment template for bolakami-worldcup.
# Copy to `.env` (or `.env.local`) and fill in the real values.
#
# These are read SERVER-SIDE by the /api/livescores route handler
# (src/app/api/livescores/route.ts) via process.env. The SportMonks token must
# stay server-side — never prefix it with NEXT_PUBLIC_ or use it in client code.

# SportMonks API token (secret).
SPORTMONKS_API_TOKEN=

# SportMonks league id for the FIFA World Cup. Defaults to 732 in the route
# handler; only set this if your plan exposes the World Cup under a different id.
WORLD_CUP_LEAGUE_ID=732
